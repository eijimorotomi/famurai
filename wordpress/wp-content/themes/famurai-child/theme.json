{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        {
          "name": "White",
          "slug": "white",
          "color": "#ffffff"
        },
        {
          "name": "Light Gray",
          "slug": "light-gray",
          "color": "#f5f5f7"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#1d1d1f"
        },
        {
          "name": "Gold",
          "slug": "gold",
          "color": "#d4a017"
        },
        {
          "name": "Crimson",
          "slug": "crimson",
          "color": "#e63946"
        },
        {
          "name": "Midnight",
          "slug": "midnight",
          "color": "#0f0f1a"
        }
      ]
    },
    "typography": {
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.25rem"
        },
        {
          "name": "X Large",
          "slug": "x-large",
          "size": "1.75rem"
        },
        {
          "name": "XX Large",
          "slug": "xx-large",
          "size": "2.5rem"
        },
        {
          "name": "Huge",
          "slug": "huge",
          "size": "clamp(2.5rem, 6vw, 3.5rem)"
        }
      ],
      "fontFamilies": [
        {
          "name": "System UI",
          "slug": "system-ui",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, sans-serif"
        }
      ]
    },
    "layout": {
      "contentSize": "860px",
      "wideSize": "1200px"
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      },
      "units": ["px", "em", "rem", "vh", "vw", "%"]
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#1d1d1f"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-ui)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.7"
    },
    "elements": {
      "link": {
        "color": {
          "text": "#1d1d1f"
        },
        ":hover": {
          "color": {
            "text": "#d4a017"
          }
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--huge)",
          "fontWeight": "700",
          "lineHeight": "1.1",
          "letterSpacing": "-0.02em"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "fontWeight": "600",
          "lineHeight": "1.2",
          "letterSpacing": "-0.01em"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "button": {
        "color": {
          "background": "#1d1d1f",
          "text": "#ffffff"
        },
        "typography": {
          "fontWeight": "500",
          "fontSize": "var(--wp--preset--font-size--medium)"
        },
        "border": {
          "radius": "980px"
        }
      }
    }
  }
}
